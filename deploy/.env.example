# Power Manage Server Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Database
# =============================================================================
# Strong password for PostgreSQL (generate with: openssl rand -base64 32)
POSTGRES_PASSWORD=CHANGE_ME_generate_a_strong_password

# Password for the read-only indexer database user (pm_indexer)
# Generate with: openssl rand -base64 32
INDEXER_POSTGRES_PASSWORD=CHANGE_ME_generate_a_strong_password

# =============================================================================
# Valkey (Task Queue & Search)
# =============================================================================
# Password for Valkey (used by control, gateway, and indexer)
# Generate with: openssl rand -base64 32
VALKEY_PASSWORD=CHANGE_ME_generate_a_strong_password

# =============================================================================
# Authentication
# =============================================================================
# JWT secret for session tokens (minimum 32 characters)
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_a_strong_secret_min_32_chars

# Initial admin account (created on first startup only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_use_a_strong_password

# =============================================================================
# Domain Configuration
# =============================================================================
# Public domain for the control server (Web UI and API)
CONTROL_DOMAIN=power-manage.example.com

# Public domain for the gateway (agent mTLS connections)
GATEWAY_DOMAIN=gateway.example.com

# =============================================================================
# TLS / Let's Encrypt
# =============================================================================
# Email address for Let's Encrypt certificate notifications
ACME_EMAIL=admin@example.com

# =============================================================================
# Encryption
# =============================================================================
# AES-256 key for encrypting secrets at rest (IdP client secrets, LUKS keys,
# LPS passwords). Must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
# WARNING: Changing this key after data has been encrypted will make existing
# encrypted secrets unrecoverable. If not set, secrets are stored unencrypted.
PM_ENCRYPTION_KEY=

# =============================================================================
# Optional — uncomment and set as needed
# =============================================================================

# --- Logging ----------------------------------------------------------------
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info
# Log format: text (human-readable) or json (structured, for log aggregators)
# LOG_FORMAT=text

# --- CORS -------------------------------------------------------------------
# Required ONLY if your web app is hosted on a different origin than the API.
# Comma-separated list of allowed origins (include the protocol).
# For same-origin deployments (web app served by the control server), leave empty.
# Example: CORS_ORIGINS=https://app.example.com
# CORS_ORIGINS=

# --- SSO / SCIM -------------------------------------------------------------
# Base URL for SSO callback redirects after OIDC authentication.
# Defaults to the first CORS_ORIGINS value. For same-origin deployments, this
# is derived automatically from the request origin — no configuration needed.
# Example: CONTROL_SSO_CALLBACK_BASE_URL=https://power-manage.example.com
# CONTROL_SSO_CALLBACK_BASE_URL=

# Base URL for SCIM v2 endpoints shown in the identity provider setup UI.
# Defaults to https://${CONTROL_DOMAIN}. Only set this if SCIM is accessed
# via a different URL than the control server.
# Example: CONTROL_SCIM_BASE_URL=https://power-manage.example.com
# CONTROL_SCIM_BASE_URL=

# --- Password Authentication ------------------------------------------------
# Set to false to disable password-based login (SSO-only deployments).
# Default: true
# CONTROL_PASSWORD_AUTH_ENABLED=true

# --- Dynamic Device Groups --------------------------------------------------
# Interval for periodic evaluation of dynamic device groups.
# Min: 30m, Max: 8h, 0 to disable. Default: 1h
# DYNAMIC_GROUP_EVAL_INTERVAL=1h

# --- Network ----------------------------------------------------------------
# Comma-separated trusted proxy IPs/CIDRs for correct client IP parsing.
# Set this when running behind a reverse proxy (Traefik is added automatically).
# Example: CONTROL_TRUSTED_PROXIES=10.0.0.1,172.16.0.0/12
# CONTROL_TRUSTED_PROXIES=

# --- SSH Access -------------------------------------------------------------
# Grant SSH access to all devices by default (default: false).
# When false, SSH access must be granted explicitly via SSH actions.
# CONTROL_SSH_ACCESS_FOR_ALL=false

# --- Docker Images ----------------------------------------------------------
# Tag for control, gateway, and indexer images (default: latest)
# IMAGE_TAG=latest
